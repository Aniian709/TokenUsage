{
  "name": "tokenusage",
  "version": "0.6.2",
  "description": "Local token usage dashboard for Codex and Claude Code on Windows, with desktop widgets and persisted history.",
  "main": "src/cli.js",
  "bin": {
    "tokenusage": "bin/tracker.js",
    "tokenusage-cli": "bin/tracker.js",
    "tokenusage-tracker": "bin/tracker.js",
    "tracker": "bin/tracker.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "dashboard/dist/",
    "CreateDesktopShortcuts.cmd",
    "InstallWidgetsRuntime.cmd",
    "TokenUsage.cmd",
    "TokenUsageStop.cmd",
    "LICENSE",
    "README.md"
  ],
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node bin/tracker.js serve",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "widgets:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-widgets-runtime.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aniian709/TokenUsage.git"
  },
  "homepage": "https://github.com/Aniian709/TokenUsage",
  "bugs": {
    "url": "https://github.com/Aniian709/TokenUsage/issues"
  },
  "keywords": [
    "token",
    "tracker",
    "ai",
    "claude",
    "codex",
    "cursor",
    "gemini",
    "kiro",
    "opencode",
    "usage",
    "cost"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
